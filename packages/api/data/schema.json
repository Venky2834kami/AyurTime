{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PrakritiAnalysis",
  "description": "Schema for a single Prakriti analysis record (JSON file store - future DB migration ready)",
  "type": "object",
  "required": ["analysisId", "userId", "dominantDosha", "scoreBreakdown", "confidence", "contributingSignals", "recommendationSummary", "createdAt", "method"],
  "properties": {
    "analysisId": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this analysis (UUID v4)"
    },
    "userId": {
      "type": "string",
      "description": "User identifier (anonymous if not logged in)"
    },
    "dominantDosha": {
      "type": "string",
      "enum": ["vata", "pitta", "kapha"],
      "description": "Primary dosha identified from analysis"
    },
    "scoreBreakdown": {
      "type": "object",
      "required": ["vata", "pitta", "kapha"],
      "properties": {
        "vata":  { "type": "number", "minimum": 0, "maximum": 1 },
        "pitta": { "type": "number", "minimum": 0, "maximum": 1 },
        "kapha": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence score of the dominant dosha classification"
    },
    "contributingSignals": {
      "type": "array",
      "items": { "type": "string", "enum": ["questionnaire", "image_analysis_placeholder", "image_analysis"] },
      "description": "Signals used to compute the analysis"
    },
    "recommendationSummary": {
      "type": "object",
      "required": ["diet", "lifestyle", "herbs"],
      "properties": {
        "diet":      { "type": "array", "items": { "type": "string" } },
        "lifestyle": { "type": "array", "items": { "type": "string" } },
        "herbs":     { "type": "array", "items": { "type": "string" } }
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO8601 timestamp of when analysis was created"
    },
    "method": {
      "type": "string",
      "enum": ["questionnaire", "image_analysis", "hybrid"],
      "description": "Method used for analysis"
    }
  },
  "additionalProperties": false
}
